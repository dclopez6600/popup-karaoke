# Netlify HTTP Headers — PopUp Karaoke
# Security + performance headers for all routes

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# HTML pages — always revalidate so updates are picked up immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Root index — same
/
  Cache-Control: public, max-age=0, must-revalidate

# CSS — 1 week (no hash versioning, so don't go immutable)
/*.css
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# JavaScript — 1 week
/*.js
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400

# Images — 1 year (change-resistant assets)
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Video — 30 days
/*.mp4
  Cache-Control: public, max-age=2592000

# Fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Sitemap + robots — short cache so search engines get updates
/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

# Service worker — never cache (must always be fresh)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest — 1 day
/manifest.json
  Cache-Control: public, max-age=86400
